#!/usr/bin/env bash

# Prune git worktrees that have been merged into main, and kill their tmux sessions.

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Not in a git repository"
    [[ -n "$TMUX_POPUP" ]] && read -n 1 -s -r -p "Press any key to close"
    exit 1
fi

main_worktree=$(git worktree list --porcelain | head -1 | sed 's/^worktree //')
repo_name=$(basename "$(git rev-parse --show-toplevel)" | tr . _)

# Find the main branch name (main or master)
if git show-ref --verify --quiet refs/heads/main; then
    main_branch="main"
elif git show-ref --verify --quiet refs/heads/master; then
    main_branch="master"
else
    echo "Could not find main or master branch"
    [[ -n "$TMUX_POPUP" ]] && read -n 1 -s -r -p "Press any key to close"
    exit 1
fi

# Prune stale remote tracking branches so we can detect merged PRs
git fetch --prune origin 2>/dev/null

# Check if a branch has been merged into main (regular merge, squash merge, or rebase)
is_merged() {
    local branch=$1

    # Skip branches with no unique commits (branch tip is the merge-base itself)
    local merge_base branch_tip
    merge_base=$(git merge-base "$main_branch" "$branch" 2>/dev/null) || return 1
    branch_tip=$(git rev-parse "$branch" 2>/dev/null) || return 1
    [[ "$branch_tip" == "$merge_base" ]] && return 0

    # Regular merge: branch tip is an ancestor of main
    if git merge-base --is-ancestor "$branch" "$main_branch" 2>/dev/null; then
        return 0
    fi

    # Squash/rebase merge: check if the upstream tracking branch was deleted
    # (GitHub deletes the remote branch after merging a PR)
    local upstream
    upstream=$(git for-each-ref --format='%(upstream:track)' "refs/heads/$branch")
    if [[ "$upstream" == "[gone]" ]]; then
        return 0
    fi

    # Squash/rebase merge: check if the branch's changes are already in main
    # by comparing the branch tree against main — if merging would produce no diff, it's merged
    local merge_base
    merge_base=$(git merge-base "$main_branch" "$branch" 2>/dev/null) || return 1
    if git diff --quiet "$main_branch"..."$branch" 2>/dev/null; then
        return 0
    fi

    return 1
}

# Build list of worktrees whose branch has been merged
prunable=""
while IFS= read -r line; do
    wt_path=$(echo "$line" | awk '{print $1}')
    # Skip the main worktree
    [[ "$wt_path" == "$main_worktree" ]] && continue

    # Get the branch for this worktree
    wt_branch=$(git worktree list | grep "^${wt_path} " | sed 's/.*\[//' | sed 's/\]//')
    [[ -z "$wt_branch" ]] && continue

    if is_merged "$wt_branch"; then
        prunable+="${line}"$'\n'
    fi
done <<< "$(git worktree list)"

prunable=$(echo "$prunable" | sed '/^$/d')

if [[ -z "$prunable" ]]; then
    echo "No worktrees with branches merged into $main_branch (checked regular, squash, and rebase merges)"
    [[ -n "$TMUX_POPUP" ]] && read -n 1 -s -r -p "Press any key to close"
    exit 0
fi

echo "Worktrees merged into $main_branch:"
echo "$prunable"
echo

# Use fzf multi-select, or if --all flag passed, prune everything
if [[ "$1" == "--all" ]]; then
    selected="$prunable"
else
    selected=$(echo "$prunable" | fzf --multi --prompt="select to prune (tab to multi-select)> " --height=100%)
fi

if [[ -z "$selected" ]]; then
    exit 0
fi

while IFS= read -r line; do
    wt_path=$(echo "$line" | awk '{print $1}')
    wt_dir=$(basename "$wt_path" | tr . _)
    wt_branch=$(git worktree list | grep "^${wt_path} " | sed 's/.*\[//' | sed 's/\]//')
    session_name="${wt_dir}"

    echo "Removing worktree: $wt_path (branch: $wt_branch)"

    # Find the tmux session — it may have a tag prefix like "[TODO] name"
    actual_session=$(tmux list-sessions -F '#S' 2>/dev/null | grep -E "^(\[[^]]*\] *)*${session_name}$" | head -1)
    if [[ -n "$actual_session" ]]; then
        # If we're currently in this session, switch to another one first
        current_session=$(tmux display-message -p '#S' 2>/dev/null)
        if [[ "$current_session" == "$actual_session" ]]; then
            next_session=$(tmux list-sessions -F '#S' | grep -v "^${actual_session}$" | head -1)
            if [[ -n "$next_session" ]]; then
                tmux switch-client -t "$next_session"
            fi
        fi
        tmux kill-session -t="$actual_session"
        echo "  Killed tmux session: $actual_session"
    fi

    # Remove the worktree (double --force handles submodules and locked worktrees)
    git worktree remove --force --force "$wt_path" 2>/dev/null

    # Fall back to rm if git left the directory behind. Guard against empty/root paths.
    if [[ -d "$wt_path" && -n "$wt_path" && "$wt_path" != "/" && "$wt_path" != "$HOME" && "$wt_path" != "$main_worktree" ]]; then
        rm -rf "$wt_path"
        echo "  Removed leftover directory: $wt_path"
    fi

    # Delete the branch
    git branch -d "$wt_branch" 2> /dev/null

    echo "  Done"
done <<< "$selected"

# Clean up any stale worktree references
git worktree prune
