#!/usr/bin/env bash

# List git worktrees and switch to a tmux session for the selected one.
# Creates a new tmux session if one doesn't exist for that worktree.

# Must be in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Not in a git repository"
    exit 1
fi

# Get worktrees: each line is "path commitish [branch]"
worktrees=$(git worktree list)

if [[ -z "$worktrees" ]]; then
    echo "No worktrees found"
    exit 1
fi

# If only one worktree (the main one), nothing to switch to
worktree_count=$(echo "$worktrees" | wc -l | tr -d ' ')
if [[ "$worktree_count" -eq 1 ]]; then
    echo "Only one worktree exists. Create more with: git worktree add"
    exit 0
fi

# Use fzf to pick a worktree
selected=$(echo "$worktrees" | fzf --prompt="worktree> " --height=40%)

if [[ -z "$selected" ]]; then
    exit 0
fi

# Extract the path (first field)
selected_path=$(echo "$selected" | awk '{print $1}')

# Derive session name from repo name + worktree directory name
repo_name=$(basename "$(git rev-parse --show-toplevel)" | tr . _)
worktree_dir=$(basename "$selected_path" | tr . _)

# For the main worktree, just use the repo name; for others, use repo/branch
if [[ "$selected_path" == "$(git worktree list --porcelain | head -1 | sed 's/^worktree //')" ]]; then
    selected_name="$repo_name"
else
    selected_name="${repo_name}/${worktree_dir}"
fi

tmux_running=$(pgrep tmux)

# If tmux is not running at all
if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$selected_name" -c "$selected_path"
    exit 0
fi

# If tmux doesn't have a session for this worktree, create one
if ! tmux has-session -t="$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected_path"
fi

# Attach or switch to session
tmux attach -t "$selected_name" 2> /dev/null || tmux switch-client -t "$selected_name"
