#!/usr/bin/env bash

# List git worktrees and switch to a tmux session for the selected one.
# Creates a new tmux session if one doesn't exist for that worktree.

# Must be in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Not in a git repository"
    [[ -n "$TMUX_POPUP" ]] && read -n 1 -s -r -p "Press any key to close"
    exit 1
fi

# Get worktrees: each line is "path commitish [branch]"
worktrees=$(git worktree list)

if [[ -z "$worktrees" ]]; then
    echo "No worktrees found"
    [[ -n "$TMUX_POPUP" ]] && read -n 1 -s -r -p "Press any key to close"
    exit 1
fi

# If only one worktree (the main one), nothing to switch to
worktree_count=$(echo "$worktrees" | wc -l | tr -d ' ')
if [[ "$worktree_count" -eq 1 ]]; then
    echo "Only one worktree exists. Create more with: git worktree add"
    [[ -n "$TMUX_POPUP" ]] && read -n 1 -s -r -p "Press any key to close"
    exit 0
fi

# Build display list: branch name (or folder name) mapped to full path
declare -A worktree_map
display_list=""
while IFS= read -r line; do
    wt_path=$(echo "$line" | awk '{print $1}')
    branch=$(echo "$line" | grep -o '\[.*\]' | tr -d '[]')
    if [[ -z "$branch" ]]; then
        branch=$(basename "$wt_path")
    fi
    # Skip worktrees that already have a tmux session
    session_name=$(echo "$branch" | tr . _)
    if tmux has-session -t="$session_name" 2> /dev/null; then
        continue
    fi
    worktree_map["$branch"]="$wt_path"
    display_list+="$branch"$'\n'
done <<< "$worktrees"
display_list=$(echo "$display_list" | sed '/^$/d')

if [[ -z "$display_list" ]]; then
    echo "All worktrees already have tmux sessions"
    [[ -n "$TMUX_POPUP" ]] && read -n 1 -s -r -p "Press any key to close"
    exit 0
fi

# Use fzf to pick a worktree
selected=$(echo "$display_list" | fzf --prompt="worktree> " --height=100%)

if [[ -z "$selected" ]]; then
    exit 0
fi

selected_path="${worktree_map[$selected]}"
selected_name=$(echo "$selected" | tr . _)

# Create the session if it doesn't exist (always detached)
if ! tmux has-session -t="$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected_path"
fi

# Switch the parent client to the session (works from inside a popup)
tmux switch-client -t "$selected_name"
